{
  "name": "classdrive-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:visual": "npm run build && playwright test e2e/00-visual.spec.ts",
    "test:visual:update": "npm run build && playwright test e2e/00-visual.spec.ts --update-snapshots",
    "test:e2e": "npm run build && playwright test",
    "capture:readme": "node ./scripts/capture-readme-screenshots.cjs"
  },
  "dependencies": {
    "element-plus": "^2.13.7",
    "pinia": "^3.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
